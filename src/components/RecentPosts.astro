---
import { getCollection } from 'astro:content';

interface Props {
	limit?: number;
}

const { limit = 5 } = Astro.props;

const posts = (await getCollection('docs'))
	.filter((entry) => entry.id.startsWith('byggdagbok/'))
	.sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
	.slice(0, limit);

const fmt = new Intl.DateTimeFormat('sv-SE', { year: 'numeric', month: 'long', day: 'numeric' });
---

<ul class="recent-posts not-content">
	{
		posts.map((post) => (
			<li>
				{post.data.date && (
					<time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
				)}
				<a href={`/${post.id}/`}>{post.data.title}</a>
				{post.data.excerpt && <p>{post.data.excerpt}</p>}
			</li>
		))
	}
</ul>

<style>
	.recent-posts {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		text-align: start;
	}
	.recent-posts li {
		border-inline-start: 2px solid var(--sl-color-gray-5);
		padding-inline-start: 1rem;
	}
	.recent-posts time {
		display: block;
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.recent-posts a {
		font-size: var(--sl-text-lg);
		font-weight: 600;
		text-decoration: none;
		color: var(--sl-color-white);
	}
	.recent-posts a:hover {
		color: var(--sl-color-text-accent);
	}
	.recent-posts p {
		margin: 0.25rem 0 0;
		color: var(--sl-color-gray-2);
		font-size: var(--sl-text-sm);
	}
</style>
